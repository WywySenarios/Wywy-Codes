---
import Layout from "../../components/layout/layout.astro";
import { ResponseForm } from "../../components/pipeline/response-form";

export function getStaticPaths() {
  return [{ params: { id: "_spa" } }];
}

const id = Astro.params.id!;
---

<Layout>
  <h1 class="text-2xl font-bold mb-2">Respond</h1>
  <ResponseForm pipelineId={id} client:only="react" />
</Layout>
